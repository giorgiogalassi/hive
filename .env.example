# Copy this file to .env and fill in the values before starting the app.
# The .env file is never committed to git and is never baked into the Docker image.

# Secret used to verify HMAC-SHA256 signatures on incoming GitHub webhook payloads.
# Set this to the same value you configure in GitHub → Settings → Webhooks → Secret.
GITHUB_WEBHOOK_SECRET=

# Personal Access Token with read AND write permissions.
# Classic PAT: repo scope. Fine-grained PAT: contents:read + issues:write.
# Write permission is required to post comments — read-only tokens fail silently.
GITHUB_TOKEN=

# --- Runtime-specific keys ---

# OAuth token for the Claude Code CLI (runner: claude-code).
# Obtain by running: claude setup-token
# This replaces the ~/.claude volume mount and works on any machine (VPS, CI, etc.).
CLAUDE_CODE_OAUTH_TOKEN=

# Required only when using runner: codex.
# OPENAI_API_KEY=

# GitHub username of the repo owner; used to identify owner PR comments that re-queue Cody
GITHUB_OWNER=your-github-username
