{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VsmN2EfcjLmTW7kfptJtAe","type":"tool_result","content":"1\t\"\"\"\n2\tloop.py — Rework-loop state and decision logic for the Hive orchestration system.\n3\t\n4\tThis module owns all decisions about whether to re-queue Cody, approve a PR, or\n5\tescalate to a human reviewer.  main.py (and any other entry point) calls into\n6\tthese functions after normalizing raw webhook events; it never makes loop\n7\tdecisions itself.\n8\t\n9\tState is stored in a module-level dict keyed by (repo, pr_number) so that every\n10\thandler within a single process shares the same view without requiring a database.\n11\t\"\"\"\n12\t\n13\tfrom __future__ import annotations\n14\t\n15\timport os\n16\t\n17\tfrom runner.vcs.port import VCSPort, PRReviewSubmittedEvent, IssueCommentEvent\n18\t\n19\t# ---------------------------------------------------------------------------\n20\t# In-process loop state\n21\t# ---------------------------------------------------------------------------\n22\t\n23\t# Keyed by (repo, pr_number).\n24\t# Each value is a dict with:\n25\t#   cody_runs           int   – number of times Cody has been re-queued\n26\t#   first_review_posted bool  – True once the first Cody review has appeared\n27\t_state: dict[tuple[str, int], dict] = {}\n28\t\n29\t# Maximum number of automated Cody re-queues before escalating to a human.\n30\t_MAX_CODY_RUNS = 3\n31\t\n32\t\n33\t# ---------------------------------------------------------------------------\n34\t# Public helpers\n35\t# ---------------------------------------------------------------------------\n36\t\n37\tdef get_state(repo: str, pr_number: int) -> dict:\n38\t    \"\"\"Return the loop state for *repo*/*pr_number*, initializing it if absent.\n39\t\n40\t    The returned dict is the live entry stored in ``_state``; callers that\n41\t    mutate it are updating the shared state directly.\n42\t\n43\t    Args:\n44\t        repo: Full repository identifier in ``owner/repo`` form.\n45\t        pr_number: Pull request number.\n46\t\n47\t    Returns:\n48\t        A dict with keys ``cody_runs`` (int) and ``first_review_posted`` (bool).\n49\t    \"\"\"\n50\t    key = (repo, pr_number)\n51\t    if key not in _state:\n52\t        _state[key] = {\"cody_runs\": 0, \"first_review_posted\": False}\n53\t    return _state[key]\n54\t\n55\t\n56\tdef on_review_submitted(vcs: VCSPort, event: PRReviewSubmittedEvent) -> str:\n57\t    \"\"\"Decide what to do when a PR review is submitted.\n58\t\n59\t    Decision table:\n60\t\n61\t    * ``\"approved\"``   → mark first review posted, return ``\"approved\"``.\n62\t    * ``\"changes_requested\"`` and ``cody_runs < 3`` → increment counter,\n63\t      mark first review posted, return ``\"requeue\"``.\n64\t    * ``\"changes_requested\"`` and ``cody_runs >= 3`` → apply the\n65\t      ``\"human:review\"`` label and return ``\"human_review\"``.\n66\t    * Any other state (e.g. ``\"commented\"``) → return ``\"ignore\"``.\n67\t\n68\t    Args:\n69\t        vcs: A :class:`~runner.vcs.port.VCSPort` implementation used for label\n70\t            operations.\n71\t        event: The normalized review-submitted event from the VCS adapter.\n72\t\n73\t    Returns:\n74\t        One of ``\"requeue\"``, ``\"approved\"``, ``\"human_review\"``, or\n75\t        ``\"ignore\"``.\n76\t    \"\"\"\n77\t    state = get_state(event.repo, event.pr_number)\n78\t\n79\t    if event.state == \"approved\":\n80\t        state[\"first_review_posted\"] = True\n81\t        return \"approved\"\n82\t\n83\t    if event.state == \"changes_requested\":\n84\t        if state[\"cody_runs\"] < _MAX_CODY_RUNS:\n85\t            state[\"cody_runs\"] += 1\n86\t            state[\"first_review_posted\"] = True\n87\t            return \"requeue\"\n88\t        else:\n89\t            # Cody has already been re-queued the maximum number of times;\n90\t            # escalate to a human reviewer by applying the label.\n91\t            vcs.apply_label(event.repo, event.pr_number, \"human:review\")\n92\t            return \"human_review\"\n93\t\n94\t    # \"commented\" and any future review states are silently ignored.\n95\t    return \"ignore\"\n96\t\n97\t\n98\tdef on_owner_comment(event: IssueCommentEvent) -> str:\n99\t    \"\"\"Decide what to do when the repo owner comments on a PR.\n100\t\n101\t    Owner comments are only meaningful after Cody has posted at least one\n102\t    review (``first_review_posted == True``).  If no Cody review exists yet\n103\t    the comment is ignored so that the initial conversation before the first\n104\t    automated review does not accidentally trigger a re-queue.\n105\t\n106\t    Unlike the automated review path, owner comments always re-queue Cody\n107\t    regardless of how many runs have already occurred — a human explicitly\n108\t    asked for more work.\n109\t\n110\t    Args:\n111\t        event: The normalized issue-comment event.  The ``number`` field is\n112\t            used as the PR number for state look-up.\n113\t\n114\t    Returns:\n115\t        ``\"requeue\"`` if a Cody review has already been posted, otherwise\n116\t        ``\"ignore\"``.\n117\t    \"\"\"\n118\t    state = get_state(event.repo, event.number)\n119\t\n120\t    if not state[\"first_review_posted\"]:\n121\t        return \"ignore\"\n122\t\n123\t    # Human comments always re-queue regardless of the run count.\n124\t    state[\"cody_runs\"] += 1\n125\t    return \"requeue\"\n126\t\n127\t\n128\tdef is_repo_owner(author: str) -> bool:\n129\t    \"\"\"Return ``True`` if *author* matches the configured repo owner.\n130\t\n131\t    The expected owner is read from the ``GITHUB_OWNER`` environment variable.\n132\t    An empty or unset variable means no author will ever match, which is a\n133\t    safe default (no unexpected re-queues).\n134\t\n135\t    Args:\n136\t        author: GitHub username to check.\n137\t\n138\t    Returns:\n139\t        ``True`` if *author* equals ``GITHUB_OWNER``, ``False`` otherwise.\n140\t    \"\"\"\n141\t    return author == os.environ.get(\"GITHUB_OWNER\", \"\")\n142\t"}]},"parent_tool_use_id":null,"session_id":"97a743dc-5824-4b18-a2bf-dbab96441b45","uuid":"f9080125-68e6-4d47-b4cb-c4b363021c00","timestamp":"2026-07-02T09:36:45.252Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/hive-cody-0h7u97zy/runner/loop.py","content":"\"\"\"\nloop.py — Rework-loop state and decision logic for the Hive orchestration system.\n\nThis module owns all decisions about whether to re-queue Cody, approve a PR, or\nescalate to a human reviewer.  main.py (and any other entry point) calls into\nthese functions after normalizing raw webhook events; it never makes loop\ndecisions itself.\n\nState is stored in a module-level dict keyed by (repo, pr_number) so that every\nhandler within a single process shares the same view without requiring a database.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport os\n\nfrom runner.vcs.port import VCSPort, PRReviewSubmittedEvent, IssueCommentEvent\n\n# ---------------------------------------------------------------------------\n# In-process loop state\n# ---------------------------------------------------------------------------\n\n# Keyed by (repo, pr_number).\n# Each value is a dict with:\n#   cody_runs           int   – number of times Cody has been re-queued\n#   first_review_posted bool  – True once the first Cody review has appeared\n_state: dict[tuple[str, int], dict] = {}\n\n# Maximum number of automated Cody re-queues before escalating to a human.\n_MAX_CODY_RUNS = 3\n\n\n# ---------------------------------------------------------------------------\n# Public helpers\n# ---------------------------------------------------------------------------\n\ndef get_state(repo: str, pr_number: int) -> dict:\n    \"\"\"Return the loop state for *repo*/*pr_number*, initializing it if absent.\n\n    The returned dict is the live entry stored in ``_state``; callers that\n    mutate it are updating the shared state directly.\n\n    Args:\n        repo: Full repository identifier in ``owner/repo`` form.\n        pr_number: Pull request number.\n\n    Returns:\n        A dict with keys ``cody_runs`` (int) and ``first_review_posted`` (bool).\n    \"\"\"\n    key = (repo, pr_number)\n    if key not in _state:\n        _state[key] = {\"cody_runs\": 0, \"first_review_posted\": False}\n    return _state[key]\n\n\ndef on_review_submitted(vcs: VCSPort, event: PRReviewSubmittedEvent) -> str:\n    \"\"\"Decide what to do when a PR review is submitted.\n\n    Decision table:\n\n    * ``\"approved\"``   → mark first review posted, return ``\"approved\"``.\n    * ``\"changes_requested\"`` and ``cody_runs < 3`` → increment counter,\n      mark first review posted, return ``\"requeue\"``.\n    * ``\"changes_requested\"`` and ``cody_runs >= 3`` → apply the\n      ``\"human:review\"`` label and return ``\"human_review\"``.\n    * Any other state (e.g. ``\"commented\"``) → return ``\"ignore\"``.\n\n    Args:\n        vcs: A :class:`~runner.vcs.port.VCSPort` implementation used for label\n            operations.\n        event: The normalized review-submitted event from the VCS adapter.\n\n    Returns:\n        One of ``\"requeue\"``, ``\"approved\"``, ``\"human_review\"``, or\n        ``\"ignore\"``.\n    \"\"\"\n    state = get_state(event.repo, event.pr_number)\n\n    if event.state == \"approved\":\n        state[\"first_review_posted\"] = True\n        return \"approved\"\n\n    if event.state == \"changes_requested\":\n        if state[\"cody_runs\"] < _MAX_CODY_RUNS:\n            state[\"cody_runs\"] += 1\n            state[\"first_review_posted\"] = True\n            return \"requeue\"\n        else:\n            # Cody has already been re-queued the maximum number of times;\n            # escalate to a human reviewer by applying the label.\n            vcs.apply_label(event.repo, event.pr_number, \"human:review\")\n            return \"human_review\"\n\n    # \"commented\" and any future review states are silently ignored.\n    return \"ignore\"\n\n\ndef on_owner_comment(event: IssueCommentEvent) -> str:\n    \"\"\"Decide what to do when the repo owner comments on a PR.\n\n    Owner comments are only meaningful after Cody has posted at least one\n    review (``first_review_posted == True``).  If no Cody review exists yet\n    the comment is ignored so that the initial conversation before the first\n    automated review does not accidentally trigger a re-queue.\n\n    Unlike the automated review path, owner comments always re-queue Cody\n    regardless of how many runs have already occurred — a human explicitly\n    asked for more work.\n\n    Args:\n        event: The normalized issue-comment event.  The ``number`` field is\n            used as the PR number for state look-up.\n\n    Returns:\n        ``\"requeue\"`` if a Cody review has already been posted, otherwise\n        ``\"ignore\"``.\n    \"\"\"\n    state = get_state(event.repo, event.number)\n\n    if not state[\"first_review_posted\"]:\n        return \"ignore\"\n\n    # Human comments always re-queue regardless of the run count.\n    state[\"cody_runs\"] += 1\n    return \"requeue\"\n\n\ndef is_repo_owner(author: str) -> bool:\n    \"\"\"Return ``True`` if *author* matches the configured repo owner.\n\n    The expected owner is read from the ``GITHUB_OWNER`` environment variable.\n    An empty or unset variable means no author will ever match, which is a\n    safe default (no unexpected re-queues).\n\n    Args:\n        author: GitHub username to check.\n\n    Returns:\n        ``True`` if *author* equals ``GITHUB_OWNER``, ``False`` otherwise.\n    \"\"\"\n    return author == os.environ.get(\"GITHUB_OWNER\", \"\")\n","numLines":142,"startLine":1,"totalLines":142}}}
