{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UfbqiMgjmNFxrhLgoC4MQh","type":"tool_result","content":"1\t\"\"\"\n2\tport.py — Abstract VCS port for the Hive orchestration system.\n3\t\n4\tDefines normalized event dataclasses and the abstract VCSPort interface.\n5\tAll types in this module are VCS-provider-agnostic: no provider-specific\n6\timports, field names, or HTTP client references appear here.  Concrete\n7\tadapters (e.g. GitHub, GitLab) live in sibling modules and inherit from\n8\tVCSPort.\n9\t\"\"\"\n10\t\n11\tfrom __future__ import annotations\n12\t\n13\tfrom abc import ABC, abstractmethod\n14\tfrom dataclasses import dataclass\n15\tfrom typing import Literal, Union\n16\t\n17\t\n18\t# ---------------------------------------------------------------------------\n19\t# Normalized event dataclasses\n20\t# ---------------------------------------------------------------------------\n21\t\n22\t@dataclass\n23\tclass PROpenedEvent:\n24\t    \"\"\"Fired when a pull request is opened against any branch.\n25\t\n26\t    Attributes:\n27\t        repo: Full repository identifier in ``owner/repo`` form.\n28\t        pr_number: Provider-assigned pull request number.\n29\t        title: Pull request title as set by the author.\n30\t        head_branch: The branch that contains the proposed changes.\n31\t        base_branch: The target branch the PR would merge into.\n32\t        author: Username of the PR author.\n33\t    \"\"\"\n34\t\n35\t    repo: str\n36\t    pr_number: int\n37\t    title: str\n38\t    head_branch: str\n39\t    base_branch: str\n40\t    author: str\n41\t\n42\t\n43\t@dataclass\n44\tclass PRLabeledEvent:\n45\t    \"\"\"Fired when a label is applied to a pull request.\n46\t\n47\t    Attributes:\n48\t        repo: Full repository identifier in ``owner/repo`` form.\n49\t        pr_number: Provider-assigned pull request number.\n50\t        label: Name of the label that was applied.\n51\t    \"\"\"\n52\t\n53\t    repo: str\n54\t    pr_number: int\n55\t    label: str\n56\t\n57\t\n58\t@dataclass\n59\tclass PRReviewSubmittedEvent:\n60\t    \"\"\"Fired when a reviewer submits a review on a pull request.\n61\t\n62\t    Attributes:\n63\t        repo: Full repository identifier in ``owner/repo`` form.\n64\t        pr_number: Provider-assigned pull request number.\n65\t        state: Review outcome — one of ``\"approved\"``, ``\"changes_requested\"``,\n66\t            or ``\"commented\"``.\n67\t        body: Review comment body, possibly empty.\n68\t        author: Username of the reviewer.\n69\t    \"\"\"\n70\t\n71\t    repo: str\n72\t    pr_number: int\n73\t    state: Literal[\"approved\", \"changes_requested\", \"commented\"]\n74\t    body: str\n75\t    author: str\n76\t\n77\t\n78\t@dataclass\n79\tclass IssueCommentEvent:\n80\t    \"\"\"Fired when a comment is posted on an issue or pull request.\n81\t\n82\t    Attributes:\n83\t        repo: Full repository identifier in ``owner/repo`` form.\n84\t        number: Issue or pull request number.\n85\t        body: Text of the comment.\n86\t        author: Username of the commenter.\n87\t        is_pr: ``True`` when the comment belongs to a pull request,\n88\t            ``False`` for a plain issue.\n89\t    \"\"\"\n90\t\n91\t    repo: str\n92\t    number: int\n93\t    body: str\n94\t    author: str\n95\t    is_pr: bool\n96\t\n97\t\n98\t@dataclass\n99\tclass IssueLabeledEvent:\n100\t    \"\"\"Fired when a label is applied to an issue.\n101\t\n102\t    Attributes:\n103\t        repo: Full repository identifier in ``owner/repo`` form.\n104\t        issue_number: Provider-assigned issue number.\n105\t        label: Name of the label that was applied.\n106\t    \"\"\"\n107\t\n108\t    repo: str\n109\t    issue_number: int\n110\t    label: str\n111\t\n112\t\n113\t# Union of all normalized event types returned by VCSPort.parse_event.\n114\tNormalizedEvent = Union[\n115\t    PROpenedEvent,\n116\t    PRLabeledEvent,\n117\t    PRReviewSubmittedEvent,\n118\t    IssueCommentEvent,\n119\t    IssueLabeledEvent,\n120\t]\n121\t\n122\t\n123\t# ---------------------------------------------------------------------------\n124\t# Abstract VCS port\n125\t# ---------------------------------------------------------------------------\n126\t\n127\tclass VCSPort(ABC):\n128\t    \"\"\"Provider-agnostic interface for all VCS operations used by Hive.\n129\t\n130\t    Concrete subclasses implement each method against a specific VCS\n131\t    provider (GitHub, GitLab, Bitbucket, …).  The rest of the system\n132\t    interacts exclusively through this interface so that provider details\n133\t    never leak into agent runners or event dispatchers.\n134\t    \"\"\"\n135\t\n136\t    @abstractmethod\n137\t    def parse_event(self, headers: dict, raw_body: bytes) -> NormalizedEvent | None:\n138\t        \"\"\"Parse a raw inbound webhook into a normalized event object.\n139\t\n140\t        Args:\n141\t            headers: HTTP request headers as a plain dict, lower-cased keys\n142\t                recommended but not required.\n143\t            raw_body: The unmodified request body bytes, as received from the\n144\t                network before any deserialization.\n145\t\n146\t        Returns:\n147\t            A :data:`NormalizedEvent` instance representing the event, or\n148\t            ``None`` when the payload describes an event type that Hive does\n149\t            not handle.\n150\t        \"\"\"\n151\t\n152\t    @abstractmethod\n153\t    def apply_label(self, repo: str, number: int, label: str) -> None:\n154\t        \"\"\"Apply *label* to issue or pull request *number* in *repo*.\n155\t\n156\t        This operation is idempotent: applying a label that is already\n157\t        present must not raise an error.\n158\t\n159\t        Args:\n160\t            repo: Full repository identifier in ``owner/repo`` form.\n161\t            number: Issue or pull request number.\n162\t            label: Name of the label to apply.\n163\t        \"\"\"\n164\t\n165\t    @abstractmethod\n166\t    def has_label(self, repo: str, number: int, label: str) -> bool:\n167\t        \"\"\"Return ``True`` if *label* is currently applied to *number*.\n168\t\n169\t        Args:\n170\t            repo: Full repository identifier in ``owner/repo`` form.\n171\t            number: Issue or pull request number.\n172\t            label: Name of the label to check.\n173\t\n174\t        Returns:\n175\t            ``True`` if the label is present, ``False`` otherwise.\n176\t        \"\"\"\n177\t\n178\t    @abstractmethod\n179\t    def post_review(\n180\t        self,\n181\t        repo: str,\n182\t        pr_number: int,\n183\t        body: str,\n184\t        state: str,\n185\t    ) -> None:\n186\t        \"\"\"Submit a review comment on a pull request.\n187\t\n188\t        Args:\n189\t            repo: Full repository identifier in ``owner/repo`` form.\n190\t            pr_number: Pull request number.\n191\t            body: Markdown body of the review.\n192\t            state: Review state string — typically ``\"APPROVE\"``,\n193\t                ``\"REQUEST_CHANGES\"``, or ``\"COMMENT\"``.\n194\t        \"\"\"\n195\t\n196\t    @abstractmethod\n197\t    def post_comment(self, repo: str, number: int, body: str) -> None:\n198\t        \"\"\"Post a plain comment on an issue or pull request.\n199\t\n200\t        Args:\n201\t            repo: Full repository identifier in ``owner/repo`` form.\n202\t            number: Issue or pull request number.\n203\t            body: Markdown body of the comment.\n204\t        \"\"\"\n205\t\n206\t    @abstractmethod\n207\t    def get_pr_diff(self, repo: str, pr_number: int, workdir: str) -> str:\n208\t        \"\"\"Return the unified diff for a pull request.\n209\t\n210\t        Args:\n211\t            repo: Full repository identifier in ``owner/repo`` form.\n212\t            pr_number: Pull request number.\n213\t            workdir: Path to a local directory where temporary git operations\n214\t                may be performed if the provider requires them.\n215\t\n216\t        Returns:\n217\t            A unified-diff string representing all changes in the PR.\n218\t        \"\"\"\n219\t\n220\t    @abstractmethod\n221\t    def list_issues(self, repo: str, label: str) -> list[dict]:\n222\t        \"\"\"Return all open issues that carry *label*.\n223\t\n224\t        Args:\n225\t            repo: Full repository identifier in ``owner/repo`` form.\n226\t            label: Label name to filter by.\n227\t\n228\t        Returns:\n229\t            A list of provider-agnostic issue dicts.  Each dict must at\n230\t            minimum contain the keys ``number``, ``title``, and ``body``.\n231\t        \"\"\"\n232\t\n233\t    @abstractmethod\n234\t    def get_issue(self, repo: str, number: int) -> dict:\n235\t        \"\"\"Return metadata for a single issue.\n236\t\n237\t        Args:\n238\t            repo: Full repository identifier in ``owner/repo`` form.\n239\t            number: Issue number.\n240\t\n241\t        Returns:\n242\t            A provider-agnostic dict containing at minimum ``number``,\n243\t            ``title``, and ``body``.\n244\t        \"\"\"\n245\t\n246\t    @abstractmethod\n247\t    def get_issue_dependencies(self, repo: str, number: int) -> list[int]:\n248\t        \"\"\"Return the issue numbers that *number* depends on.\n249\t\n250\t        Implementations should parse dependency references from the issue\n251\t        body (e.g. ``Blocked by: #12``) and return them as a list of ints.\n252\t\n253\t        Args:\n254\t            repo: Full repository identifier in ``owner/repo`` form.\n255\t            number: Issue number whose dependencies are requested.\n256\t\n257\t        Returns:\n258\t            A (possibly empty) list of issue numbers that must be resolved\n259\t            before *number* can proceed.\n260\t        \"\"\"\n261\t"}]},"parent_tool_use_id":null,"session_id":"97a743dc-5824-4b18-a2bf-dbab96441b45","uuid":"78326ff0-3074-447a-9821-1fa088015347","timestamp":"2026-07-02T09:36:56.210Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/hive-cody-0h7u97zy/runner/vcs/port.py","content":"\"\"\"\nport.py — Abstract VCS port for the Hive orchestration system.\n\nDefines normalized event dataclasses and the abstract VCSPort interface.\nAll types in this module are VCS-provider-agnostic: no provider-specific\nimports, field names, or HTTP client references appear here.  Concrete\nadapters (e.g. GitHub, GitLab) live in sibling modules and inherit from\nVCSPort.\n\"\"\"\n\nfrom __future__ import annotations\n\nfrom abc import ABC, abstractmethod\nfrom dataclasses import dataclass\nfrom typing import Literal, Union\n\n\n# ---------------------------------------------------------------------------\n# Normalized event dataclasses\n# ---------------------------------------------------------------------------\n\n@dataclass\nclass PROpenedEvent:\n    \"\"\"Fired when a pull request is opened against any branch.\n\n    Attributes:\n        repo: Full repository identifier in ``owner/repo`` form.\n        pr_number: Provider-assigned pull request number.\n        title: Pull request title as set by the author.\n        head_branch: The branch that contains the proposed changes.\n        base_branch: The target branch the PR would merge into.\n        author: Username of the PR author.\n    \"\"\"\n\n    repo: str\n    pr_number: int\n    title: str\n    head_branch: str\n    base_branch: str\n    author: str\n\n\n@dataclass\nclass PRLabeledEvent:\n    \"\"\"Fired when a label is applied to a pull request.\n\n    Attributes:\n        repo: Full repository identifier in ``owner/repo`` form.\n        pr_number: Provider-assigned pull request number.\n        label: Name of the label that was applied.\n    \"\"\"\n\n    repo: str\n    pr_number: int\n    label: str\n\n\n@dataclass\nclass PRReviewSubmittedEvent:\n    \"\"\"Fired when a reviewer submits a review on a pull request.\n\n    Attributes:\n        repo: Full repository identifier in ``owner/repo`` form.\n        pr_number: Provider-assigned pull request number.\n        state: Review outcome — one of ``\"approved\"``, ``\"changes_requested\"``,\n            or ``\"commented\"``.\n        body: Review comment body, possibly empty.\n        author: Username of the reviewer.\n    \"\"\"\n\n    repo: str\n    pr_number: int\n    state: Literal[\"approved\", \"changes_requested\", \"commented\"]\n    body: str\n    author: str\n\n\n@dataclass\nclass IssueCommentEvent:\n    \"\"\"Fired when a comment is posted on an issue or pull request.\n\n    Attributes:\n        repo: Full repository identifier in ``owner/repo`` form.\n        number: Issue or pull request number.\n        body: Text of the comment.\n        author: Username of the commenter.\n        is_pr: ``True`` when the comment belongs to a pull request,\n            ``False`` for a plain issue.\n    \"\"\"\n\n    repo: str\n    number: int\n    body: str\n    author: str\n    is_pr: bool\n\n\n@dataclass\nclass IssueLabeledEvent:\n    \"\"\"Fired when a label is applied to an issue.\n\n    Attributes:\n        repo: Full repository identifier in ``owner/repo`` form.\n        issue_number: Provider-assigned issue number.\n        label: Name of the label that was applied.\n    \"\"\"\n\n    repo: str\n    issue_number: int\n    label: str\n\n\n# Union of all normalized event types returned by VCSPort.parse_event.\nNormalizedEvent = Union[\n    PROpenedEvent,\n    PRLabeledEvent,\n    PRReviewSubmittedEvent,\n    IssueCommentEvent,\n    IssueLabeledEvent,\n]\n\n\n# ---------------------------------------------------------------------------\n# Abstract VCS port\n# ---------------------------------------------------------------------------\n\nclass VCSPort(ABC):\n    \"\"\"Provider-agnostic interface for all VCS operations used by Hive.\n\n    Concrete subclasses implement each method against a specific VCS\n    provider (GitHub, GitLab, Bitbucket, …).  The rest of the system\n    interacts exclusively through this interface so that provider details\n    never leak into agent runners or event dispatchers.\n    \"\"\"\n\n    @abstractmethod\n    def parse_event(self, headers: dict, raw_body: bytes) -> NormalizedEvent | None:\n        \"\"\"Parse a raw inbound webhook into a normalized event object.\n\n        Args:\n            headers: HTTP request headers as a plain dict, lower-cased keys\n                recommended but not required.\n            raw_body: The unmodified request body bytes, as received from the\n                network before any deserialization.\n\n        Returns:\n            A :data:`NormalizedEvent` instance representing the event, or\n            ``None`` when the payload describes an event type that Hive does\n            not handle.\n        \"\"\"\n\n    @abstractmethod\n    def apply_label(self, repo: str, number: int, label: str) -> None:\n        \"\"\"Apply *label* to issue or pull request *number* in *repo*.\n\n        This operation is idempotent: applying a label that is already\n        present must not raise an error.\n\n        Args:\n            repo: Full repository identifier in ``owner/repo`` form.\n            number: Issue or pull request number.\n            label: Name of the label to apply.\n        \"\"\"\n\n    @abstractmethod\n    def has_label(self, repo: str, number: int, label: str) -> bool:\n        \"\"\"Return ``True`` if *label* is currently applied to *number*.\n\n        Args:\n            repo: Full repository identifier in ``owner/repo`` form.\n            number: Issue or pull request number.\n            label: Name of the label to check.\n\n        Returns:\n            ``True`` if the label is present, ``False`` otherwise.\n        \"\"\"\n\n    @abstractmethod\n    def post_review(\n        self,\n        repo: str,\n        pr_number: int,\n        body: str,\n        state: str,\n    ) -> None:\n        \"\"\"Submit a review comment on a pull request.\n\n        Args:\n            repo: Full repository identifier in ``owner/repo`` form.\n            pr_number: Pull request number.\n            body: Markdown body of the review.\n            state: Review state string — typically ``\"APPROVE\"``,\n                ``\"REQUEST_CHANGES\"``, or ``\"COMMENT\"``.\n        \"\"\"\n\n    @abstractmethod\n    def post_comment(self, repo: str, number: int, body: str) -> None:\n        \"\"\"Post a plain comment on an issue or pull request.\n\n        Args:\n            repo: Full repository identifier in ``owner/repo`` form.\n            number: Issue or pull request number.\n            body: Markdown body of the comment.\n        \"\"\"\n\n    @abstractmethod\n    def get_pr_diff(self, repo: str, pr_number: int, workdir: str) -> str:\n        \"\"\"Return the unified diff for a pull request.\n\n        Args:\n            repo: Full repository identifier in ``owner/repo`` form.\n            pr_number: Pull request number.\n            workdir: Path to a local directory where temporary git operations\n                may be performed if the provider requires them.\n\n        Returns:\n            A unified-diff string representing all changes in the PR.\n        \"\"\"\n\n    @abstractmethod\n    def list_issues(self, repo: str, label: str) -> list[dict]:\n        \"\"\"Return all open issues that carry *label*.\n\n        Args:\n            repo: Full repository identifier in ``owner/repo`` form.\n            label: Label name to filter by.\n\n        Returns:\n            A list of provider-agnostic issue dicts.  Each dict must at\n            minimum contain the keys ``number``, ``title``, and ``body``.\n        \"\"\"\n\n    @abstractmethod\n    def get_issue(self, repo: str, number: int) -> dict:\n        \"\"\"Return metadata for a single issue.\n\n        Args:\n            repo: Full repository identifier in ``owner/repo`` form.\n            number: Issue number.\n\n        Returns:\n            A provider-agnostic dict containing at minimum ``number``,\n            ``title``, and ``body``.\n        \"\"\"\n\n    @abstractmethod\n    def get_issue_dependencies(self, repo: str, number: int) -> list[int]:\n        \"\"\"Return the issue numbers that *number* depends on.\n\n        Implementations should parse dependency references from the issue\n        body (e.g. ``Blocked by: #12``) and return them as a list of ints.\n\n        Args:\n            repo: Full repository identifier in ``owner/repo`` form.\n            number: Issue number whose dependencies are requested.\n\n        Returns:\n            A (possibly empty) list of issue numbers that must be resolved\n            before *number* can proceed.\n        \"\"\"\n","numLines":261,"startLine":1,"totalLines":261}}}
