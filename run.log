{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014FGHHfwu6Ab6Z9RYGYwWds","type":"tool_result","content":"1\t\"\"\"\n2\tmain.py — FastAPI webhook receiver for the Hive GitHub automation system.\n3\t\n4\tListens for inbound GitHub webhook events, validates their HMAC-SHA256 signature\n5\tto confirm they originate from GitHub, and dispatches the appropriate agent as a\n6\tbackground task based on the normalized event type returned by the VCS port.\n7\t\n8\tAll event parsing and VCS operations are delegated to the GitHubAdapter so that\n9\tno GitHub-specific webhook field names appear outside the adapter.  The one\n10\texception is the HMAC signature header ``X-Hub-Signature-256``, which must be\n11\tread directly here as part of the security infrastructure before any event\n12\tparsing takes place.\n13\t\"\"\"\n14\t\n15\timport hashlib\n16\timport hmac\n17\timport logging\n18\timport os\n19\t\n20\tfrom fastapi import BackgroundTasks, FastAPI, Request\n21\tfrom fastapi.responses import JSONResponse, PlainTextResponse\n22\t\n23\tfrom runner import agent_runner\n24\tfrom runner import loop\n25\tfrom runner.vcs.github_adapter import GitHubAdapter\n26\tfrom runner.vcs.port import (\n27\t    IssueCommentEvent,\n28\t    IssueLabeledEvent,\n29\t    PRLabeledEvent,\n30\t    PROpenedEvent,\n31\t    PRReviewSubmittedEvent,\n32\t)\n33\t\n34\tlogging.basicConfig(level=logging.INFO)\n35\tlogger = logging.getLogger(__name__)\n36\t\n37\t# The shared secret configured in the GitHub repository's webhook settings.\n38\t# Required at startup: the server refuses to run without it because every\n39\t# incoming request must be signature-verified before processing.\n40\t_SECRET = os.environ.get(\"GITHUB_WEBHOOK_SECRET\")\n41\tif not _SECRET:\n42\t    raise RuntimeError(\n43\t        \"GITHUB_WEBHOOK_SECRET environment variable is not set. \"\n44\t        \"The webhook receiver cannot start without it.\"\n45\t    )\n46\t\n47\t# Pre-encode the secret once so every request can compute the HMAC digest\n48\t# without repeatedly encoding the same string.\n49\t_SECRET_BYTES: bytes = _SECRET.encode()\n50\t\n51\t# Resolve the agents directory relative to this file so the path stays correct\n52\t# regardless of the working directory from which the server is launched.\n53\t_AGENTS_DIR = os.path.join(os.path.dirname(__file__), \"..\", \"agents\")\n54\t\n55\t# Single VCS adapter instance shared across all requests.  GitHubAdapter owns\n56\t# all GitHub-specific field names; nothing else in this module may reference\n57\t# provider-specific payload keys.\n58\t_vcs = GitHubAdapter()\n59\t\n60\tapp = FastAPI()\n61\t\n62\t\n63\t@app.post(\"/webhook\")\n64\tasync def webhook(request: Request, background_tasks: BackgroundTasks) -> JSONResponse:\n65\t    \"\"\"Handle an inbound GitHub webhook POST request.\n66\t\n67\t    Performs the following steps in order:\n68\t\n69\t    1. **Signature validation** — Computes the expected HMAC-SHA256 digest of\n70\t       the raw request body using the shared webhook secret and compares it to\n71\t       the ``X-Hub-Signature-256`` header supplied by GitHub.  Requests that\n72\t       are missing the header or whose digest does not match are rejected with\n73\t       HTTP 401.\n74\t\n75\t    2. **Event parsing** — Delegates payload interpretation to\n76\t       :meth:`~runner.vcs.github_adapter.GitHubAdapter.parse_event`, which\n77\t       returns a normalized event object or ``None`` for unhandled event types.\n78\t\n79\t    3. **Dispatch** — Switches on the concrete type of the normalized event and\n80\t       schedules the appropriate agent as a FastAPI background task:\n81\t\n82\t       - :class:`~runner.vcs.port.IssueLabeledEvent` with ``agent:analyze``\n83\t         → dispatches ``issue-reviewer.yaml``.\n84\t       - :class:`~runner.vcs.port.IssueLabeledEvent` with ``agent:develop``\n85\t         → dispatches ``cody.yaml``.\n86\t       - :class:`~runner.vcs.port.PROpenedEvent`\n87\t         → idempotently applies the ``agent:review`` label so the resulting\n88\t         :class:`~runner.vcs.port.PRLabeledEvent` fires Reven.\n89\t       - :class:`~runner.vcs.port.PRLabeledEvent` with ``agent:review``\n90\t         → dispatches ``reven.yaml`` via :func:`agent_runner.run_for_pr`.\n91\t       - :class:`~runner.vcs.port.PRReviewSubmittedEvent`\n92\t         → delegates to :func:`loop.on_review_submitted`; re-queues\n93\t         ``cody.yaml`` on ``\"requeue\"``, logs on ``\"approved\"`` /\n94\t         ``\"human_review\"``.\n95\t       - :class:`~runner.vcs.port.IssueCommentEvent` on a PR from the repo\n96\t         owner → delegates to :func:`loop.on_owner_comment`; re-queues\n97\t         ``cody.yaml`` on ``\"requeue\"``.\n98\t\n99\t    Args:\n100\t        request: The incoming FastAPI request object containing headers and body.\n101\t        background_tasks: FastAPI dependency used to schedule the agent run after\n102\t            the HTTP response has been sent.\n103\t\n104\t    Returns:\n105\t        A JSON response with ``{\"status\": \"ok\"}`` on success, or a plain-text\n106\t        error message with HTTP 401 if signature validation fails.\n107\t    \"\"\"\n108\t    # Read the raw bytes before any parsing so the HMAC is computed over the\n109\t    # exact bytes that GitHub signed, not a re-serialised version of the payload.\n110\t    body: bytes = await request.body()\n111\t\n112\t    # --- Signature validation ---\n113\t    # The X-Hub-Signature-256 header is read here intentionally: it is security\n114\t    # infrastructure that must run before any event parsing, not a business-logic\n115\t    # payload field.  This is the only GitHub-specific string permitted in main.py.\n116\t    signature_header = request.headers.get(\"X-Hub-Signature-256\")\n117\t    if not signature_header:\n118\t        return PlainTextResponse(\n119\t            content=\"Missing X-Hub-Signature-256 header\",\n120\t            status_code=401,\n121\t        )\n122\t\n123\t    expected_digest = (\n124\t        \"sha256=\"\n125\t        + hmac.new(_SECRET_BYTES, body, hashlib.sha256).hexdigest()\n126\t    )\n127\t\n128\t    # Use hmac.compare_digest to prevent timing attacks that could reveal the\n129\t    # secret by measuring how long a byte-by-byte comparison takes.\n130\t    if not hmac.compare_digest(expected_digest, signature_header):\n131\t        return PlainTextResponse(\n132\t            content=\"Invalid signature\",\n133\t            status_code=401,\n134\t        )\n135\t\n136\t    # --- Event parsing via VCS port ---\n137\t    # parse_event returns None for ping events and any other unhandled types;\n138\t    # we acknowledge them with 200 without further processing.\n139\t    event = _vcs.parse_event(dict(request.headers), body)\n140\t\n141\t    if event is None:\n142\t        logger.info(\"parse_event returned None — unhandled or ping event, acknowledging\")\n143\t        return JSONResponse(content={\"status\": \"ok\"}, status_code=200)\n144\t\n145\t    logger.info(\"event=%s\", type(event).__name__)\n146\t\n147\t    github_token = os.environ.get(\"GITHUB_TOKEN\", \"\")\n148\t\n149\t    # --- Dispatch on normalized event type ---\n150\t\n151\t    if isinstance(event, IssueLabeledEvent):\n152\t        _dispatch_issue_labeled(event, github_token, background_tasks)\n153\t\n154\t    elif isinstance(event, PROpenedEvent):\n155\t        _handle_pr_opened(event)\n156\t\n157\t    elif isinstance(event, PRLabeledEvent):\n158\t        _dispatch_pr_labeled(event, github_token, background_tasks)\n159\t\n160\t    elif isinstance(event, PRReviewSubmittedEvent):\n161\t        _handle_review_submitted(event, github_token, background_tasks)\n162\t\n163\t    elif isinstance(event, IssueCommentEvent) and event.is_pr:\n164\t        _handle_owner_pr_comment(event, github_token, background_tasks)\n165\t\n166\t    return JSONResponse(content={\"status\": \"ok\"}, status_code=200)\n167\t\n168\t\n169\t# ---------------------------------------------------------------------------\n170\t# Private dispatch helpers\n171\t# ---------------------------------------------------------------------------\n172\t\n173\t\n174\tdef _dispatch_issue_labeled(\n175\t    event: IssueLabeledEvent,\n176\t    github_token: str,\n177\t    background_tasks: BackgroundTasks,\n178\t) -> None:\n179\t    \"\"\"Dispatch an agent when a label is applied to an issue.\n180\t\n181\t    Fetches the issue title and body via the VCS port so the agent receives\n182\t    the full context it needs, then schedules the appropriate YAML runner as\n183\t    a background task.\n184\t\n185\t    Args:\n186\t        event: Normalized issue-labeled event.\n187\t        github_token: GitHub personal access token injected into the agent context.\n188\t        background_tasks: FastAPI background task registry.\n189\t    \"\"\"\n190\t    if event.label not in (\"agent:analyze\", \"agent:develop\"):\n191\t        logger.debug(\"IssueLabeledEvent: unhandled label=%s — ignoring\", event.label)\n192\t        return\n193\t\n194\t    # Fetch the issue details so the agent receives useful context.\n195\t    try:\n196\t        issue_details = _vcs.get_issue(event.repo, event.issue_number)\n197\t    except Exception:\n198\t        logger.exception(\n199\t            \"IssueLabeledEvent: could not fetch issue details for %s#%d\",\n200\t            event.repo, event.issue_number,\n201\t        )\n202\t        issue_details = {\"title\": \"\", \"body\": \"\"}\n203\t\n204\t    context = {\n205\t        \"repo_full_name\": event.repo,\n206\t        \"issue_number\": event.issue_number,\n207\t        \"issue_title\": issue_details.get(\"title\", \"\"),\n208\t        \"issue_body\": issue_details.get(\"body\", \"\"),\n209\t        \"label\": event.label,\n210\t        \"github_token\": github_token,\n211\t    }\n212\t\n213\t    if event.label == \"agent:analyze\":\n214\t        agent_yaml = \"issue-reviewer.yaml\"\n215\t    else:\n216\t        # \"agent:develop\"\n217\t        agent_yaml = \"cody.yaml\"\n218\t\n219\t    yaml_path = os.path.join(_AGENTS_DIR, agent_yaml)\n220\t    logger.info(\n221\t        \"dispatching label=%s agent=%s issue=#%d repo=%s\",\n222\t        event.label, agent_yaml, event.issue_number, event.repo,\n223\t    )\n224\t    background_tasks.add_task(agent_runner.run, yaml_path, context)\n225\t\n226\t\n227\tdef _handle_pr_opened(event: PROpenedEvent) -> None:\n228\t    \"\"\"Idempotently apply the ``agent:review`` label when a PR is opened.\n229\t\n230\t    The label application triggers a ``PRLabeledEvent`` webhook, which then\n231\t    fires Reven.  No agent is dispatched directly from this handler.\n232\t\n233\t    Args:\n234\t        event: Normalized PR-opened event.\n235\t    \"\"\"\n236\t    try:\n237\t        already_labeled = _vcs.has_label(event.repo, event.pr_number, \"agent:review\")\n238\t    except Exception:\n239\t        logger.exception(\n240\t            \"PROpenedEvent: could not check labels for %s#%d\",\n241\t            event.repo, event.pr_number,\n242\t        )\n243\t        return\n244\t\n245\t    if not already_labeled:\n246\t        try:\n247\t            _vcs.apply_label(event.repo, event.pr_number, \"agent:review\")\n248\t            logger.info(\n249\t                \"PROpenedEvent: applied agent:review to pr=#%d repo=%s\",\n250\t                event.pr_number, event.repo,\n251\t            )\n252\t        except Exception:\n253\t            logger.exception(\n254\t                \"PROpenedEvent: could not apply agent:review to %s#%d\",\n255\t                event.repo, event.pr_number,\n256\t            )\n257\t    else:\n258\t        logger.debug(\n259\t            \"PROpenedEvent: agent:review already present on pr=#%d repo=%s\",\n260\t            event.pr_number, event.repo,\n261\t        )\n262\t\n263\t\n264\tdef _dispatch_pr_labeled(\n265\t    event: PRLabeledEvent,\n266\t    github_token: str,\n267\t    background_tasks: BackgroundTasks,\n268\t) -> None:\n269\t    \"\"\"Dispatch Reven when the ``agent:review`` label is applied to a PR.\n270\t\n271\t    Fetches PR metadata (title, body) via the VCS port and builds the full\n272\t    PR context required by :func:`agent_runner.run_for_pr`.  Head and base\n273\t    branches are left empty because GitHub's issues API endpoint does not\n274\t    return branch information for pull requests.\n275\t\n276\t    Args:\n277\t        event: Normalized PR-labeled event.\n278\t        github_token: GitHub personal access token injected into the agent context.\n279\t        background_tasks: FastAPI background task registry.\n280\t    \"\"\"\n281\t    if event.label != \"agent:review\":\n282\t        logger.debug(\"PRLabeledEvent: unhandled label=%s — ignoring\", event.label)\n283\t        return\n284\t\n285\t    # Use the issues endpoint (works for PR numbers too) to retrieve title/body.\n286\t    try:\n287\t        pr_details = _vcs.get_issue(event.repo, event.pr_number)\n288\t    except Exception:\n289\t        logger.exception(\n290\t            \"PRLabeledEvent: could not fetch PR details for %s#%d\",\n291\t            event.repo, event.pr_number,\n292\t        )\n293\t        pr_details = {\"title\": \"\", \"body\": \"\"}\n294\t\n295\t    pr_context = {\n296\t        \"repo_full_name\": event.repo,\n297\t        \"pr_number\": event.pr_number,\n298\t        \"pr_title\": pr_details.get(\"title\", \"\"),\n299\t        \"pr_body\": pr_details.get(\"body\", \"\"),\n300\t        \"head_branch\": \"\",\n301\t        \"base_branch\": \"\",\n302\t        \"review_body\": \"\",\n303\t        \"github_token\": github_token,\n304\t    }\n305\t\n306\t    yaml_path = os.path.join(_AGENTS_DIR, \"reven.yaml\")\n307\t    logger.info(\n308\t        \"dispatching label=%s agent=reven.yaml pr=#%d repo=%s\",\n309\t        event.label, event.pr_number, event.repo,\n310\t    )\n311\t    background_tasks.add_task(agent_runner.run_for_pr, yaml_path, pr_context, _vcs)\n312\t\n313\t\n314\tdef _handle_review_submitted(\n315\t    event: PRReviewSubmittedEvent,\n316\t    github_token: str,\n317\t    background_tasks: BackgroundTasks,\n318\t) -> None:\n319\t    \"\"\"Act on the outcome of a PR review submission.\n320\t\n321\t    Delegates the loop decision to :func:`loop.on_review_submitted` and\n322\t    re-queues Cody when the result is ``\"requeue\"``.\n323\t\n324\t    Args:\n325\t        event: Normalized PR-review-submitted event.\n326\t        github_token: GitHub personal access token injected into the agent context.\n327\t        background_tasks: FastAPI background task registry.\n328\t    \"\"\"\n329\t    result = loop.on_review_submitted(_vcs, event)\n330\t\n331\t    if result == \"requeue\":\n332\t        pr_context = {\n333\t            \"repo_full_name\": event.repo,\n334\t            \"pr_number\": event.pr_number,\n335\t            \"pr_title\": \"\",\n336\t            \"pr_body\": \"\",\n337\t            \"head_branch\": \"\",\n338\t            \"base_branch\": \"\",\n339\t            \"review_body\": event.body,\n340\t            \"github_token\": github_token,\n341\t        }\n342\t        yaml_path = os.path.join(_AGENTS_DIR, \"cody.yaml\")\n343\t        logger.info(\n344\t            \"PRReviewSubmittedEvent: requeuing cody.yaml for pr=#%d repo=%s\",\n345\t            event.pr_number, event.repo,\n346\t        )\n347\t        background_tasks.add_task(agent_runner.run_for_pr, yaml_path, pr_context, _vcs)\n348\t\n349\t    elif result == \"approved\":\n350\t        logger.info(\n351\t            \"PRReviewSubmittedEvent: pr=#%d approved — no action required\",\n352\t            event.pr_number,\n353\t        )\n354\t\n355\t    elif result == \"human_review\":\n356\t        logger.info(\n357\t            \"PRReviewSubmittedEvent: pr=#%d escalated to human review — label already applied\",\n358\t            event.pr_number,\n359\t        )\n360\t\n361\t\n362\tdef _handle_owner_pr_comment(\n363\t    event: IssueCommentEvent,\n364\t    github_token: str,\n365\t    background_tasks: BackgroundTasks,\n366\t) -> None:\n367\t    \"\"\"Re-queue Cody when the repo owner comments on a PR.\n368\t\n369\t    Checks :func:`loop.is_repo_owner` to confirm the commenter is the owner\n370\t    configured via ``GITHUB_OWNER``, then delegates to\n371\t    :func:`loop.on_owner_comment` for the loop-state decision.\n372\t\n373\t    Args:\n374\t        event: Normalized issue-comment event where ``is_pr`` is ``True``.\n375\t        github_token: GitHub personal access token injected into the agent context.\n376\t        background_tasks: FastAPI background task registry.\n377\t    \"\"\"\n378\t    if not loop.is_repo_owner(event.author):\n379\t        logger.debug(\n380\t            \"IssueCommentEvent: author=%s is not repo owner — ignoring\",\n381\t            event.author,\n382\t        )\n383\t        return\n384\t\n385\t    result = loop.on_owner_comment(event)\n386\t\n387\t    if result == \"requeue\":\n388\t        pr_context = {\n389\t            \"repo_full_name\": event.repo,\n390\t            \"pr_number\": event.number,\n391\t            \"pr_title\": \"\",\n392\t            \"pr_body\": \"\",\n393\t            \"head_branch\": \"\",\n394\t            \"base_branch\": \"\",\n395\t            \"review_body\": event.body,\n396\t            \"github_token\": github_token,\n397\t        }\n398\t        yaml_path = os.path.join(_AGENTS_DIR, \"cody.yaml\")\n399\t        logger.info(\n400\t            \"IssueCommentEvent: owner requeue cody.yaml for pr=#%d repo=%s\",\n401\t            event.number, event.repo,\n402\t        )\n403\t        background_tasks.add_task(agent_runner.run_for_pr, yaml_path, pr_context, _vcs)\n404\t    else:\n405\t        logger.debug(\n406\t            \"IssueCommentEvent: owner comment on pr=#%d — loop returned ignore\",\n407\t            event.number,\n408\t        )\n409\t"}]},"parent_tool_use_id":null,"session_id":"97a743dc-5824-4b18-a2bf-dbab96441b45","uuid":"62fa5280-bc27-4a0d-95b4-a4f8c877464c","timestamp":"2026-07-02T09:36:17.214Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/hive-cody-0h7u97zy/runner/main.py","content":"\"\"\"\nmain.py — FastAPI webhook receiver for the Hive GitHub automation system.\n\nListens for inbound GitHub webhook events, validates their HMAC-SHA256 signature\nto confirm they originate from GitHub, and dispatches the appropriate agent as a\nbackground task based on the normalized event type returned by the VCS port.\n\nAll event parsing and VCS operations are delegated to the GitHubAdapter so that\nno GitHub-specific webhook field names appear outside the adapter.  The one\nexception is the HMAC signature header ``X-Hub-Signature-256``, which must be\nread directly here as part of the security infrastructure before any event\nparsing takes place.\n\"\"\"\n\nimport hashlib\nimport hmac\nimport logging\nimport os\n\nfrom fastapi import BackgroundTasks, FastAPI, Request\nfrom fastapi.responses import JSONResponse, PlainTextResponse\n\nfrom runner import agent_runner\nfrom runner import loop\nfrom runner.vcs.github_adapter import GitHubAdapter\nfrom runner.vcs.port import (\n    IssueCommentEvent,\n    IssueLabeledEvent,\n    PRLabeledEvent,\n    PROpenedEvent,\n    PRReviewSubmittedEvent,\n)\n\nlogging.basicConfig(level=logging.INFO)\nlogger = logging.getLogger(__name__)\n\n# The shared secret configured in the GitHub repository's webhook settings.\n# Required at startup: the server refuses to run without it because every\n# incoming request must be signature-verified before processing.\n_SECRET = os.environ.get(\"GITHUB_WEBHOOK_SECRET\")\nif not _SECRET:\n    raise RuntimeError(\n        \"GITHUB_WEBHOOK_SECRET environment variable is not set. \"\n        \"The webhook receiver cannot start without it.\"\n    )\n\n# Pre-encode the secret once so every request can compute the HMAC digest\n# without repeatedly encoding the same string.\n_SECRET_BYTES: bytes = _SECRET.encode()\n\n# Resolve the agents directory relative to this file so the path stays correct\n# regardless of the working directory from which the server is launched.\n_AGENTS_DIR = os.path.join(os.path.dirname(__file__), \"..\", \"agents\")\n\n# Single VCS adapter instance shared across all requests.  GitHubAdapter owns\n# all GitHub-specific field names; nothing else in this module may reference\n# provider-specific payload keys.\n_vcs = GitHubAdapter()\n\napp = FastAPI()\n\n\n@app.post(\"/webhook\")\nasync def webhook(request: Request, background_tasks: BackgroundTasks) -> JSONResponse:\n    \"\"\"Handle an inbound GitHub webhook POST request.\n\n    Performs the following steps in order:\n\n    1. **Signature validation** — Computes the expected HMAC-SHA256 digest of\n       the raw request body using the shared webhook secret and compares it to\n       the ``X-Hub-Signature-256`` header supplied by GitHub.  Requests that\n       are missing the header or whose digest does not match are rejected with\n       HTTP 401.\n\n    2. **Event parsing** — Delegates payload interpretation to\n       :meth:`~runner.vcs.github_adapter.GitHubAdapter.parse_event`, which\n       returns a normalized event object or ``None`` for unhandled event types.\n\n    3. **Dispatch** — Switches on the concrete type of the normalized event and\n       schedules the appropriate agent as a FastAPI background task:\n\n       - :class:`~runner.vcs.port.IssueLabeledEvent` with ``agent:analyze``\n         → dispatches ``issue-reviewer.yaml``.\n       - :class:`~runner.vcs.port.IssueLabeledEvent` with ``agent:develop``\n         → dispatches ``cody.yaml``.\n       - :class:`~runner.vcs.port.PROpenedEvent`\n         → idempotently applies the ``agent:review`` label so the resulting\n         :class:`~runner.vcs.port.PRLabeledEvent` fires Reven.\n       - :class:`~runner.vcs.port.PRLabeledEvent` with ``agent:review``\n         → dispatches ``reven.yaml`` via :func:`agent_runner.run_for_pr`.\n       - :class:`~runner.vcs.port.PRReviewSubmittedEvent`\n         → delegates to :func:`loop.on_review_submitted`; re-queues\n         ``cody.yaml`` on ``\"requeue\"``, logs on ``\"approved\"`` /\n         ``\"human_review\"``.\n       - :class:`~runner.vcs.port.IssueCommentEvent` on a PR from the repo\n         owner → delegates to :func:`loop.on_owner_comment`; re-queues\n         ``cody.yaml`` on ``\"requeue\"``.\n\n    Args:\n        request: The incoming FastAPI request object containing headers and body.\n        background_tasks: FastAPI dependency used to schedule the agent run after\n            the HTTP response has been sent.\n\n    Returns:\n        A JSON response with ``{\"status\": \"ok\"}`` on success, or a plain-text\n        error message with HTTP 401 if signature validation fails.\n    \"\"\"\n    # Read the raw bytes before any parsing so the HMAC is computed over the\n    # exact bytes that GitHub signed, not a re-serialised version of the payload.\n    body: bytes = await request.body()\n\n    # --- Signature validation ---\n    # The X-Hub-Signature-256 header is read here intentionally: it is security\n    # infrastructure that must run before any event parsing, not a business-logic\n    # payload field.  This is the only GitHub-specific string permitted in main.py.\n    signature_header = request.headers.get(\"X-Hub-Signature-256\")\n    if not signature_header:\n        return PlainTextResponse(\n            content=\"Missing X-Hub-Signature-256 header\",\n            status_code=401,\n        )\n\n    expected_digest = (\n        \"sha256=\"\n        + hmac.new(_SECRET_BYTES, body, hashlib.sha256).hexdigest()\n    )\n\n    # Use hmac.compare_digest to prevent timing attacks that could reveal the\n    # secret by measuring how long a byte-by-byte comparison takes.\n    if not hmac.compare_digest(expected_digest, signature_header):\n        return PlainTextResponse(\n            content=\"Invalid signature\",\n            status_code=401,\n        )\n\n    # --- Event parsing via VCS port ---\n    # parse_event returns None for ping events and any other unhandled types;\n    # we acknowledge them with 200 without further processing.\n    event = _vcs.parse_event(dict(request.headers), body)\n\n    if event is None:\n        logger.info(\"parse_event returned None — unhandled or ping event, acknowledging\")\n        return JSONResponse(content={\"status\": \"ok\"}, status_code=200)\n\n    logger.info(\"event=%s\", type(event).__name__)\n\n    github_token = os.environ.get(\"GITHUB_TOKEN\", \"\")\n\n    # --- Dispatch on normalized event type ---\n\n    if isinstance(event, IssueLabeledEvent):\n        _dispatch_issue_labeled(event, github_token, background_tasks)\n\n    elif isinstance(event, PROpenedEvent):\n        _handle_pr_opened(event)\n\n    elif isinstance(event, PRLabeledEvent):\n        _dispatch_pr_labeled(event, github_token, background_tasks)\n\n    elif isinstance(event, PRReviewSubmittedEvent):\n        _handle_review_submitted(event, github_token, background_tasks)\n\n    elif isinstance(event, IssueCommentEvent) and event.is_pr:\n        _handle_owner_pr_comment(event, github_token, background_tasks)\n\n    return JSONResponse(content={\"status\": \"ok\"}, status_code=200)\n\n\n# ---------------------------------------------------------------------------\n# Private dispatch helpers\n# ---------------------------------------------------------------------------\n\n\ndef _dispatch_issue_labeled(\n    event: IssueLabeledEvent,\n    github_token: str,\n    background_tasks: BackgroundTasks,\n) -> None:\n    \"\"\"Dispatch an agent when a label is applied to an issue.\n\n    Fetches the issue title and body via the VCS port so the agent receives\n    the full context it needs, then schedules the appropriate YAML runner as\n    a background task.\n\n    Args:\n        event: Normalized issue-labeled event.\n        github_token: GitHub personal access token injected into the agent context.\n        background_tasks: FastAPI background task registry.\n    \"\"\"\n    if event.label not in (\"agent:analyze\", \"agent:develop\"):\n        logger.debug(\"IssueLabeledEvent: unhandled label=%s — ignoring\", event.label)\n        return\n\n    # Fetch the issue details so the agent receives useful context.\n    try:\n        issue_details = _vcs.get_issue(event.repo, event.issue_number)\n    except Exception:\n        logger.exception(\n            \"IssueLabeledEvent: could not fetch issue details for %s#%d\",\n            event.repo, event.issue_number,\n        )\n        issue_details = {\"title\": \"\", \"body\": \"\"}\n\n    context = {\n        \"repo_full_name\": event.repo,\n        \"issue_number\": event.issue_number,\n        \"issue_title\": issue_details.get(\"title\", \"\"),\n        \"issue_body\": issue_details.get(\"body\", \"\"),\n        \"label\": event.label,\n        \"github_token\": github_token,\n    }\n\n    if event.label == \"agent:analyze\":\n        agent_yaml = \"issue-reviewer.yaml\"\n    else:\n        # \"agent:develop\"\n        agent_yaml = \"cody.yaml\"\n\n    yaml_path = os.path.join(_AGENTS_DIR, agent_yaml)\n    logger.info(\n        \"dispatching label=%s agent=%s issue=#%d repo=%s\",\n        event.label, agent_yaml, event.issue_number, event.repo,\n    )\n    background_tasks.add_task(agent_runner.run, yaml_path, context)\n\n\ndef _handle_pr_opened(event: PROpenedEvent) -> None:\n    \"\"\"Idempotently apply the ``agent:review`` label when a PR is opened.\n\n    The label application triggers a ``PRLabeledEvent`` webhook, which then\n    fires Reven.  No agent is dispatched directly from this handler.\n\n    Args:\n        event: Normalized PR-opened event.\n    \"\"\"\n    try:\n        already_labeled = _vcs.has_label(event.repo, event.pr_number, \"agent:review\")\n    except Exception:\n        logger.exception(\n            \"PROpenedEvent: could not check labels for %s#%d\",\n            event.repo, event.pr_number,\n        )\n        return\n\n    if not already_labeled:\n        try:\n            _vcs.apply_label(event.repo, event.pr_number, \"agent:review\")\n            logger.info(\n                \"PROpenedEvent: applied agent:review to pr=#%d repo=%s\",\n                event.pr_number, event.repo,\n            )\n        except Exception:\n            logger.exception(\n                \"PROpenedEvent: could not apply agent:review to %s#%d\",\n                event.repo, event.pr_number,\n            )\n    else:\n        logger.debug(\n            \"PROpenedEvent: agent:review already present on pr=#%d repo=%s\",\n            event.pr_number, event.repo,\n        )\n\n\ndef _dispatch_pr_labeled(\n    event: PRLabeledEvent,\n    github_token: str,\n    background_tasks: BackgroundTasks,\n) -> None:\n    \"\"\"Dispatch Reven when the ``agent:review`` label is applied to a PR.\n\n    Fetches PR metadata (title, body) via the VCS port and builds the full\n    PR context required by :func:`agent_runner.run_for_pr`.  Head and base\n    branches are left empty because GitHub's issues API endpoint does not\n    return branch information for pull requests.\n\n    Args:\n        event: Normalized PR-labeled event.\n        github_token: GitHub personal access token injected into the agent context.\n        background_tasks: FastAPI background task registry.\n    \"\"\"\n    if event.label != \"agent:review\":\n        logger.debug(\"PRLabeledEvent: unhandled label=%s — ignoring\", event.label)\n        return\n\n    # Use the issues endpoint (works for PR numbers too) to retrieve title/body.\n    try:\n        pr_details = _vcs.get_issue(event.repo, event.pr_number)\n    except Exception:\n        logger.exception(\n            \"PRLabeledEvent: could not fetch PR details for %s#%d\",\n            event.repo, event.pr_number,\n        )\n        pr_details = {\"title\": \"\", \"body\": \"\"}\n\n    pr_context = {\n        \"repo_full_name\": event.repo,\n        \"pr_number\": event.pr_number,\n        \"pr_title\": pr_details.get(\"title\", \"\"),\n        \"pr_body\": pr_details.get(\"body\", \"\"),\n        \"head_branch\": \"\",\n        \"base_branch\": \"\",\n        \"review_body\": \"\",\n        \"github_token\": github_token,\n    }\n\n    yaml_path = os.path.join(_AGENTS_DIR, \"reven.yaml\")\n    logger.info(\n        \"dispatching label=%s agent=reven.yaml pr=#%d repo=%s\",\n        event.label, event.pr_number, event.repo,\n    )\n    background_tasks.add_task(agent_runner.run_for_pr, yaml_path, pr_context, _vcs)\n\n\ndef _handle_review_submitted(\n    event: PRReviewSubmittedEvent,\n    github_token: str,\n    background_tasks: BackgroundTasks,\n) -> None:\n    \"\"\"Act on the outcome of a PR review submission.\n\n    Delegates the loop decision to :func:`loop.on_review_submitted` and\n    re-queues Cody when the result is ``\"requeue\"``.\n\n    Args:\n        event: Normalized PR-review-submitted event.\n        github_token: GitHub personal access token injected into the agent context.\n        background_tasks: FastAPI background task registry.\n    \"\"\"\n    result = loop.on_review_submitted(_vcs, event)\n\n    if result == \"requeue\":\n        pr_context = {\n            \"repo_full_name\": event.repo,\n            \"pr_number\": event.pr_number,\n            \"pr_title\": \"\",\n            \"pr_body\": \"\",\n            \"head_branch\": \"\",\n            \"base_branch\": \"\",\n            \"review_body\": event.body,\n            \"github_token\": github_token,\n        }\n        yaml_path = os.path.join(_AGENTS_DIR, \"cody.yaml\")\n        logger.info(\n            \"PRReviewSubmittedEvent: requeuing cody.yaml for pr=#%d repo=%s\",\n            event.pr_number, event.repo,\n        )\n        background_tasks.add_task(agent_runner.run_for_pr, yaml_path, pr_context, _vcs)\n\n    elif result == \"approved\":\n        logger.info(\n            \"PRReviewSubmittedEvent: pr=#%d approved — no action required\",\n            event.pr_number,\n        )\n\n    elif result == \"human_review\":\n        logger.info(\n            \"PRReviewSubmittedEvent: pr=#%d escalated to human review — label already applied\",\n            event.pr_number,\n        )\n\n\ndef _handle_owner_pr_comment(\n    event: IssueCommentEvent,\n    github_token: str,\n    background_tasks: BackgroundTasks,\n) -> None:\n    \"\"\"Re-queue Cody when the repo owner comments on a PR.\n\n    Checks :func:`loop.is_repo_owner` to confirm the commenter is the owner\n    configured via ``GITHUB_OWNER``, then delegates to\n    :func:`loop.on_owner_comment` for the loop-state decision.\n\n    Args:\n        event: Normalized issue-comment event where ``is_pr`` is ``True``.\n        github_token: GitHub personal access token injected into the agent context.\n        background_tasks: FastAPI background task registry.\n    \"\"\"\n    if not loop.is_repo_owner(event.author):\n        logger.debug(\n            \"IssueCommentEvent: author=%s is not repo owner — ignoring\",\n            event.author,\n        )\n        return\n\n    result = loop.on_owner_comment(event)\n\n    if result == \"requeue\":\n        pr_context = {\n            \"repo_full_name\": event.repo,\n            \"pr_number\": event.number,\n            \"pr_title\": \"\",\n            \"pr_body\": \"\",\n            \"head_branch\": \"\",\n            \"base_branch\": \"\",\n            \"review_body\": event.body,\n            \"github_token\": github_token,\n        }\n        yaml_path = os.path.join(_AGENTS_DIR, \"cody.yaml\")\n        logger.info(\n            \"IssueCommentEvent: owner requeue cody.yaml for pr=#%d repo=%s\",\n            event.number, event.repo,\n        )\n        background_tasks.add_task(agent_runner.run_for_pr, yaml_path, pr_context, _vcs)\n    else:\n        logger.debug(\n            \"IssueCommentEvent: owner comment on pr=#%d — loop returned ignore\",\n            event.number,\n        )\n","numLines":409,"startLine":1,"totalLines":409}}}
